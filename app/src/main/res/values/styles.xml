<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Legacy AppTheme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorControlNormal">#FF0000</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.DrinkApp.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="cornerRadius">@dimen/corner_radius_sm</item>
    </style>
    
    <style name="Widget.DrinkApp.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="cornerRadius">@dimen/corner_radius_sm</item>
    </style>
    
    <style name="Widget.DrinkApp.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
    </style>
    
    <!-- Card Styles -->
    <style name="Widget.DrinkApp.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_radius_md</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
        <item name="contentPadding">@dimen/spacing_md</item>
    </style>
    
    <style name="Widget.DrinkApp.CardView.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/corner_radius_md</item>
        <item name="contentPadding">@dimen/spacing_md</item>
    </style>
    
    <!-- TextInputLayout Styles -->
    <style name="Widget.DrinkApp.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_sm</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_sm</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_sm</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_sm</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextAppearance.DrinkApp.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    
    <!-- ShapeableImageView Styles -->
    <style name="RoundedSquare">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>
