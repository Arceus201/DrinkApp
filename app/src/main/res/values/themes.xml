<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Material 3 -->
    <style name="Theme.DrinkApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        
        <!-- Secondary colors -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        
        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
        
        <!-- Error colors -->
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        
        <!-- Surface colors -->
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        
        <!-- Outline colors -->
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>
        
        <!-- Typography - Material 3 Type Scale -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.DrinkApp.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.DrinkApp.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.DrinkApp.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.DrinkApp.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.DrinkApp.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.DrinkApp.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.DrinkApp.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.DrinkApp.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.DrinkApp.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.DrinkApp.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.DrinkApp.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.DrinkApp.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.DrinkApp.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.DrinkApp.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.DrinkApp.LabelSmall</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/md_theme_light_surface</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <!-- Typography Styles - Material 3 Type Scale -->
    <!-- Display styles -->
    <style name="TextAppearance.DrinkApp.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">57sp</item>
        <item name="android:lineHeight">64sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textSize">45sp</item>
        <item name="android:lineHeight">52sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">36sp</item>
        <item name="android:lineHeight">44sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <!-- Headline styles -->
    <style name="TextAppearance.DrinkApp.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:lineHeight">40sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">36sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">32sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <!-- Title styles -->
    <style name="TextAppearance.DrinkApp.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:lineHeight">28sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Body styles -->
    <style name="TextAppearance.DrinkApp.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <!-- Label styles -->
    <style name="TextAppearance.DrinkApp.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.DrinkApp.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- Legacy theme for backward compatibility -->
    <style name="Theme.DrinkApp.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.DrinkApp.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <style name="Theme.DrinkApp.PopupOverlay" parent="ThemeOverlay.Material3.Light" />
</resources>