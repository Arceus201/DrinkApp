<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/page_confirm_order"
            app:titleTextAppearance="@style/TextAppearance.DrinkApp.TitleLarge" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Delivery Address Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/corner_radius_md"
                app:cardElevation="@dimen/elevation_sm"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Address Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_address"
                            app:tint="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:text="@string/address_order"
                            android:textAppearance="@style/TextAppearance.DrinkApp.TitleMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_edit_address"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:text="@string/edit"
                            android:textAppearance="@style/TextAppearance.DrinkApp.LabelLarge" />

                    </LinearLayout>

                    <!-- Contact Info -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.DrinkApp.BodyMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold"
                            tools:text="Nguyễn Văn A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:text="|"
                            android:textAppearance="@style/TextAppearance.DrinkApp.BodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/textt_phone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.DrinkApp.BodyMedium"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="0123456789" />
                    </LinearLayout>

                    <!-- Address -->
                    <TextView
                        android:id="@+id/text_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TextAppearance.DrinkApp.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="123 Đường ABC, Phường XYZ, Quận 1, TP.HCM" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Order Items Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/text_order_confirm"
                android:textAppearance="@style/TextAppearance.DrinkApp.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/corner_radius_md"
                app:cardElevation="@dimen/elevation_sm"
                app:strokeWidth="0dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:padding="@dimen/spacing_sm"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_order_detail" />

            </com.google.android.material.card.MaterialCardView>

            <!-- PayPal Fee Section (Conditional) -->
            <LinearLayout
                android:id="@+id/layout_paypal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/corner_radius_md"
                    app:cardElevation="@dimen/elevation_sm"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <!-- Net Amount -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/fee_drink"
                                android:textAppearance="@style/TextAppearance.DrinkApp.BodyLarge"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/text_net_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.DrinkApp.BodyLarge"
                                android:textColor="?attr/colorError"
                                android:textStyle="bold"
                                tools:text="10.00" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_xs"
                                android:text="@string/USD"
                                android:textAppearance="@style/TextAppearance.DrinkApp.BodyMedium"
                                android:textColor="?attr/colorError" />
                        </LinearLayout>

                        <!-- PayPal Fee -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/fee_paypal"
                                android:textAppearance="@style/TextAppearance.DrinkApp.BodyLarge"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/text_paypal_fee"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.DrinkApp.BodyLarge"
                                android:textColor="?attr/colorError"
                                android:textStyle="bold"
                                tools:text="0.50" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_xs"
                                android:text="@string/USD"
                                android:textAppearance="@style/TextAppearance.DrinkApp.BodyMedium"
                                android:textColor="?attr/colorError" />
                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Total Price Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/corner_radius_md"
                app:cardElevation="@dimen/elevation_sm"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/text_revenue_total_price"
                        android:textAppearance="@style/TextAppearance.DrinkApp.TitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_total_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.DrinkApp.TitleLarge"
                        android:textColor="?attr/colorError"
                        android:textStyle="bold"
                        tools:text="250,000" />

                    <TextView
                        android:id="@+id/text_don_vi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="@string/vnd"
                        android:textAppearance="@style/TextAppearance.DrinkApp.TitleMedium"
                        android:textColor="?attr/colorError"
                        android:textStyle="bold" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Payment Required Notice -->
            <TextView
                android:id="@+id/text_check"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center"
                android:text="@string/greater_than_200"
                android:textAppearance="@style/TextAppearance.DrinkApp.BodyMedium"
                android:textColor="?attr/colorError"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Payment Method Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/payment_type"
                android:textAppearance="@style/TextAppearance.DrinkApp.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/corner_radius_md"
                app:cardElevation="@dimen/elevation_sm"
                app:strokeWidth="0dp">

                <RadioGroup
                    android:id="@+id/radioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio_Cash"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:text="@string/text_cash"
                        android:textAppearance="@style/TextAppearance.DrinkApp.BodyLarge" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio_Transfer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:text="@string/text_transfer"
                        android:textAppearance="@style/TextAppearance.DrinkApp.BodyLarge" />
                </RadioGroup>

            </com.google.android.material.card.MaterialCardView>

            <!-- PayPal Button (Conditional) -->
            <LinearLayout
                android:id="@+id/layout_button_paypal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:orientation="vertical"
                android:visibility="gone">

                <com.paypal.checkout.paymentbutton.PaymentButtonContainer
                    android:id="@+id/payment_button_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:paypal_button_color="blue"
                    app:paypal_button_enabled="true"
                    app:paypal_button_label="pay"
                    app:paypal_button_shape="rectangle"
                    app:paypal_button_size="large" />
            </LinearLayout>

            <!-- Confirm Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/confirm_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:minHeight="@dimen/touch_target_min"
                android:text="@string/page_confirm_order"
                android:textAppearance="@style/TextAppearance.DrinkApp.LabelLarge"
                app:cornerRadius="@dimen/corner_radius_md" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
